# Server
PORT=8001
ENV=development

# Turso (SQLite)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# CDN base URL (public R2 custom domain)
CDN_BASE_URL=https://cdn.example.com

# Cloudflare R2 (for admin uploads)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_ACCESS_KEY_SECRET=your-secret-key
R2_BUCKET_NAME=anime-gifs

# Admin API key (for programmatic access)
ADMIN_API_KEY=your-secret-admin-key

# Admin login (for the admin web panel)
ADMIN_USER=admin
ADMIN_PASS=your-secret-password

# CORS (comma-separated for multiple origins)
CORS_ALLOWED_ORIGIN=https://gifukai.com

# Frontend URL (for OAuth redirects)
FRONTEND_URL=https://gifukai.com

# Google One Tap (only client ID needed)
GOOGLE_CLIENT_ID=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=https://api.gifukai.com/auth/github/callback
